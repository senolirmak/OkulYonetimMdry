[Unit]
Description=Okul Tahtası Bildirim Ajanı
After=network.target graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/tahta_agent/agent.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Servis root olarak çalışır (notify-send için kullanıcı ortamına erişmek gerekir)
User=root

# Gizli anahtar bu dosyadan okunur.
# Dosya izinleri: sudo chmod 600 /etc/tahta_agent/secrets
# Dosya içeriği:  GIZLI_ANAHTAR=buraya-guclu-bir-anahtar-yazin
EnvironmentFile=/etc/tahta_agent/secrets

[Install]
WantedBy=multi-user.target
